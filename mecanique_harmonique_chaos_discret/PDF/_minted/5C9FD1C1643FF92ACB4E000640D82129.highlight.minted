\PYG{l+s}{subsubsection \PYGZdq{}}\PYG{n}{A1.1}\PYG{+w}{ }\PYG{n}{Unites}\PYG{+w}{ }\PYG{n}{admissibles\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{prime\PYGZus{}nat}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}prime\PYGZus{}nat p \PYGZlt{}\PYGZhy{}\PYGZgt{} (p \PYGZgt{} 1 \PYGZam{} (ALL m. m dvd p \PYGZhy{}\PYGZhy{}\PYGZgt{} m = 1 | m = p))\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{admissible\PYGZus{}unit}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}admissible\PYGZus{}unit p \PYGZlt{}\PYGZhy{}\PYGZgt{} prime\PYGZus{}nat p\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{unit}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}unit p = sqrt (real p) + 1\PYGZdq{}}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.2 Carres emboites\PYGZdq{}}

\PYG{k}{type\PYGZus{}synonym}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{o}{=}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}real * real\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{side}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}side n = (1.5 :: real) \PYGZca{} n\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{A}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A = (0,0)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{B}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}B n = (side n, 0)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C n = (side n, side n)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{D}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}D n = (0, side n)\PYGZdq{}}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.3 Triangles inscrits\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Le triangle inscrit dans le carre de niveau n et associe a l\PYGZsq{}unite p possede}
\PYG{l+s}{  les sommets :}

\PYG{l+s}{      C(n), P1(n,p), P2(n,p)}

\PYG{l+s}{  ou la base repose sur les axes et le sommet est C(n).}
\PYG{l+s}{\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{base\PYGZus{}param}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}base\PYGZus{}param n p = (side n) / (sqrt (real p) + 0.5)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{P1}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}P1 n p = (base\PYGZus{}param n p, 0)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{P2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}P2 n p = (0, base\PYGZus{}param n p)\PYGZdq{}}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.4 Rapport fondamental : demi\PYGZhy{}base / hauteur = sqrt(p)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{dist2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}point =\PYGZgt{} point =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}dist2 P Q = sqrt ((fst P \PYGZhy{} fst Q)\PYGZca{}2 + (snd P \PYGZhy{} snd Q)\PYGZca{}2)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{base\PYGZus{}length}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}base\PYGZus{}length n p = dist2 (P1 n p) (P2 n p)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{height\PYGZus{}length}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}height\PYGZus{}length n p =}
\PYG{l+s}{     abs ((2 * side n \PYGZhy{} base\PYGZus{}param n p) / sqrt 2)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{ratio\PYGZus{}halfbase\PYGZus{}height}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}ratio\PYGZus{}halfbase\PYGZus{}height n p =}
\PYG{l+s}{     ((base\PYGZus{}length n p) / 2) / (height\PYGZus{}length n p)\PYGZdq{}}

\PYG{k}{axiomatization}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{n}{ratio\PYGZus{}axiom}\PYG{o}{:}
\PYG{+w}{    }\PYG{l+s}{\PYGZdq{}admissible\PYGZus{}unit p ==\PYGZgt{} n \PYGZgt{}= 1}
\PYG{l+s}{     ==\PYGZgt{} ratio\PYGZus{}halfbase\PYGZus{}height n p = sqrt (real p)\PYGZdq{}}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.5 Angle associe a l\PYGZsq{}unite p\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{angle\PYGZus{}rect}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}angle\PYGZus{}rect p = arctan (sqrt (real p))\PYGZdq{}}

\PYG{+w}{ }\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.3 Triangles inscrits\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Le triangle inscrit dans le carre de niveau n et associe a l\PYGZsq{}unite p possede}
\PYG{l+s}{  les sommets :}

\PYG{l+s}{      C(n), P1(n,p), P2(n,p)}

\PYG{l+s}{  ou la base repose sur les axes et le sommet est C(n).}
\PYG{l+s}{\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{base\PYGZus{}param}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}base\PYGZus{}param n p = (side n) / (sqrt (real p) + 0.5)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{P1}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}P1 n p = (base\PYGZus{}param n p, 0)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{P2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}P2 n p = (0, base\PYGZus{}param n p)\PYGZdq{}}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.4 Rapport fondamental : demi\PYGZhy{}base / hauteur = sqrt(p)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{dist2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}point =\PYGZgt{} point =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}dist2 P Q = sqrt ((fst P \PYGZhy{} fst Q)\PYGZca{}2 + (snd P \PYGZhy{} snd Q)\PYGZca{}2)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{base\PYGZus{}length}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}base\PYGZus{}length n p = dist2 (P1 n p) (P2 n p)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{height\PYGZus{}length}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}height\PYGZus{}length n p =}
\PYG{l+s}{     abs ((2 * side n \PYGZhy{} base\PYGZus{}param n p) / sqrt 2)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{ratio\PYGZus{}halfbase\PYGZus{}height}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}ratio\PYGZus{}halfbase\PYGZus{}height n p =}
\PYG{l+s}{     ((base\PYGZus{}length n p) / 2) / (height\PYGZus{}length n p)\PYGZdq{}}

\PYG{k}{axiomatization}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{n}{ratio\PYGZus{}axiom}\PYG{o}{:}
\PYG{+w}{    }\PYG{l+s}{\PYGZdq{}admissible\PYGZus{}unit p ==\PYGZgt{} n \PYGZgt{}= 1}
\PYG{l+s}{     ==\PYGZgt{} ratio\PYGZus{}halfbase\PYGZus{}height n p = sqrt (real p)\PYGZdq{}}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.5 Angle associe a l\PYGZsq{}unite p\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{angle\PYGZus{}rect}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}angle\PYGZus{}rect p = arctan (sqrt (real p))\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}B2.0 Angle oppose dans le demi\PYGZhy{}triangle rectangle\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Lorsque la diagonale AC coupe la base du triangle inscrit, celui\PYGZhy{}ci est divise}
\PYG{l+s}{  en deux triangles rectangles. Dans chacun de ces triangles rectangles, la}
\PYG{l+s}{  demi\PYGZhy{}base vaut b/2 et la hauteur vaut h. Le rapport geometrique fondamental est :}

\PYG{l+s}{      (b / 2) / h = sqrt(p)}

\PYG{l+s}{  L\PYGZsq{}angle oppose a la demi\PYGZhy{}base est donc :}

\PYG{l+s}{      theta(p) = arctan(sqrt(p))}

\PYG{l+s}{  Cette fonction joue un role central dans la matrice a derivee premiere.}
\PYG{l+s}{\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}B2.1 Angle oppose pour la matrice a derivee premiere\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Nous reutilisons la fonction angle\PYGZus{}rect definie dans le Chapitre A.}
\PYG{l+s}{  Elle encode l\PYGZsq{}angle du demi\PYGZhy{}triangle rectangle associe a l\PYGZsq{}unite p.}
\PYG{l+s}{\PYGZdq{}}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{angle\PYGZus{}rect\PYGZus{}prime}\PYG{o}{:}
\PYG{+w}{  }\PYG{k+kp}{assumes}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}prime\PYGZus{}nat p\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{shows}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}angle\PYGZus{}rect p = arctan (sqrt (real p))\PYGZdq{}}
\PYG{+w}{  }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{angle\PYGZus{}rect\PYGZus{}def}\PYG{o}{)}


\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.6 Unite geometrique via le segment AL\PYGZus{}nat\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  On definit le segment AL\PYGZus{}nat(p) de maniere a ce que l\PYGZsq{}unite geometrique :}

\PYG{l+s}{      U(p) = sqrt 4.5 / AL\PYGZus{}nat(p)}

\PYG{l+s}{  soit egale a l\PYGZsq{}unite abstraite sqrt(p) + 1.}

\PYG{l+s}{  On obtient :}

\PYG{l+s}{      AL\PYGZus{}nat(p) = sqrt 4.5 / (sqrt p + 1).}
\PYG{l+s}{\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{AL\PYGZus{}nat}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}AL\PYGZus{}nat p = sqrt 4.5 / (sqrt (real p) + 1)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{geometric\PYGZus{}unit}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}geometric\PYGZus{}unit p = sqrt 4.5 / AL\PYGZus{}nat p\PYGZdq{}}


\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{geometric\PYGZus{}unit\PYGZus{}eq\PYGZus{}unit}\PYG{o}{:}
\PYG{+w}{  }\PYG{k+kp}{assumes}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}AL\PYGZus{}nat p \PYGZti{}= 0\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{shows}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}geometric\PYGZus{}unit p = sqrt (real p) + 1\PYGZdq{}}
\PYG{k}{proof}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}
\PYG{+w}{  }\PYG{k}{have}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}geometric\PYGZus{}unit p = sqrt 4.5 / AL\PYGZus{}nat p\PYGZdq{}}
\PYG{+w}{    }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{geometric\PYGZus{}unit\PYGZus{}def}\PYG{o}{)}
\PYG{+w}{  }\PYG{k}{also}\PYG{+w}{ }\PYG{k}{have}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}... = sqrt 4.5 / (sqrt 4.5 / (sqrt (real p) + 1))\PYGZdq{}}
\PYG{+w}{    }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{AL\PYGZus{}nat\PYGZus{}def}\PYG{o}{)}
\PYG{+w}{  }\PYG{k}{also}\PYG{+w}{ }\PYG{k}{have}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}... = sqrt (real p) + 1\PYGZdq{}}
\PYG{+w}{    }\PYG{k}{using}\PYG{+w}{ }\PYG{n}{assms}\PYG{+w}{ }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{field\PYGZus{}simps}\PYG{o}{)}
\PYG{+w}{  }\PYG{k}{finally}\PYG{+w}{ }\PYG{k}{show}\PYG{+w}{ }\PYG{o}{?}\PYG{n}{thesis}\PYG{+w}{ }\PYG{o+ow}{.}
\PYG{k}{qed}


\PYG{k}{axiomatization}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{n}{AL\PYGZus{}nat\PYGZus{}domain}\PYG{o}{:}
\PYG{+w}{    }\PYG{l+s}{\PYGZdq{}admissible\PYGZus{}unit p ==\PYGZgt{} AL\PYGZus{}nat p \PYGZti{}= 0\PYGZdq{}}

\PYG{g+gu}{subsubsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}A1.6 Axiome d\PYGZsq{}invariance (version demontree)\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Pour toute unite admissible p, l\PYGZsq{}unite geometrique definie par AL\PYGZus{}nat(p)}
\PYG{l+s}{  coincide avec l\PYGZsq{}unite abstraite sqrt(p) + 1.}
\PYG{l+s}{\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{u\PYGZus{}nat}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}u\PYGZus{}nat p = sqrt (real p) + 1\PYGZdq{}}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{invariance\PYGZus{}geometric\PYGZus{}unit}\PYG{o}{:}
\PYG{+w}{  }\PYG{k+kp}{assumes}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}admissible\PYGZus{}unit p\PYGZdq{}}
\PYG{+w}{  }\PYG{k+kp}{shows}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}geometric\PYGZus{}unit p = u\PYGZus{}nat p\PYGZdq{}}
\PYG{k}{proof}\PYG{+w}{ }\PYG{o}{\PYGZhy{}}
\PYG{+w}{  }\PYG{k}{have}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}AL\PYGZus{}nat p \PYGZti{}= 0\PYGZdq{}}
\PYG{+w}{    }\PYG{k}{using}\PYG{+w}{ }\PYG{n}{assms}\PYG{+w}{ }\PYG{n}{AL\PYGZus{}nat\PYGZus{}domain}\PYG{+w}{ }\PYG{k}{by}\PYG{+w}{ }\PYG{n}{blast}
\PYG{+w}{  }\PYG{k}{hence}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}geometric\PYGZus{}unit p = sqrt (real p) + 1\PYGZdq{}}
\PYG{+w}{    }\PYG{k}{using}\PYG{+w}{ }\PYG{n}{geometric\PYGZus{}unit\PYGZus{}eq\PYGZus{}unit}\PYG{+w}{ }\PYG{k}{by}\PYG{+w}{ }\PYG{n}{blast}
\PYG{+w}{  }\PYG{k}{thus}\PYG{+w}{ }\PYG{o}{?}\PYG{n}{thesis}
\PYG{+w}{    }\PYG{k}{by}\PYG{+w}{ }\PYG{o}{(}\PYG{n}{simp}\PYG{+w}{ }\PYG{n}{add}\PYG{o}{:}\PYG{+w}{ }\PYG{n}{u\PYGZus{}nat\PYGZus{}def}\PYG{o}{)}
\PYG{k}{qed}
\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}B1.0 Cardan sans blocage (formalise)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{pol}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}real =\PYGZgt{} real =\PYGZgt{} point\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}pol r theta = (r * cos theta, r * sin theta)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{ang\PYGZus{}BDE}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}ang\PYGZus{}BDE = (pi / 3)\PYGZdq{}}\PYG{+w}{     }\PYG{c}{(* 60 deg *)}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{ang\PYGZus{}CGF}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}ang\PYGZus{}CGF = (5*pi / 12)\PYGZdq{}}\PYG{+w}{  }\PYG{c}{(* 75 deg *)}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{ang\PYGZus{}BAC}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}ang\PYGZus{}BAC = (pi / 4)\PYGZdq{}}\PYG{+w}{     }\PYG{c}{(* 45 deg *)}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{BD\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}BD\PYGZus{}len = sqrt (1/3)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{DE\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}DE\PYGZus{}len = sqrt (1/12)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{BC\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}BC\PYGZus{}len = 0.5\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{EF\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}EF\PYGZus{}len = 0.5\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{FG\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}FG\PYGZus{}len = 1 / (sqrt (12 :: real) + 4)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{CG\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}CG\PYGZus{}len = 1 / (sqrt (3 :: real) + 2)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{AB\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}AB\PYGZus{}len = 1 / (sqrt (12 :: real) \PYGZhy{} 2)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{AC\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}AC\PYGZus{}len = sqrt (1.5 :: real) / 2\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{DG\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}DG\PYGZus{}len = 1.26\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{AG\PYGZus{}len}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}AG\PYGZus{}len = 1.13\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}D}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}D = (0,0)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}G}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}G = pol DG\PYGZus{}len 0\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}A}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}A = pol AG\PYGZus{}len ang\PYGZus{}BDE\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}B}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}B = pol BD\PYGZus{}len ang\PYGZus{}BDE\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}E}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}E = pol DE\PYGZus{}len (ang\PYGZus{}BDE + ang\PYGZus{}BDE)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}C}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}C = pol AC\PYGZus{}len (ang\PYGZus{}BDE \PYGZhy{} ang\PYGZus{}BAC)\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}F}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}F = pol EF\PYGZus{}len (ang\PYGZus{}BDE \PYGZhy{} ang\PYGZus{}BAC + (pi/2))\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{card\PYGZus{}G2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{point}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}card\PYGZus{}G2 = pol CG\PYGZus{}len (ang\PYGZus{}BDE \PYGZhy{} ang\PYGZus{}BAC \PYGZhy{} ang\PYGZus{}CGF)\PYGZdq{}}


\PYG{g+gh}{chapter}\PYG{+w}{ }\PYG{n}{C}
\PYG{g+gu}{section}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C1.0 Matrice a derivee premiere\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Formalisation de la matrice a derivee premiere associee au cardan sans blocage.}
\PYG{l+s}{\PYGZdq{}}

