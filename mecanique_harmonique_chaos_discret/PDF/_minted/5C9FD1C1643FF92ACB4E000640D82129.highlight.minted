\PYG{+w}{  }\PYG{n}{AG}\PYG{+w}{      }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{length}
\PYG{+w}{  }\PYG{n}{AC}\PYG{+w}{      }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{length}
\PYG{+w}{  }\PYG{n}{CG}\PYG{+w}{      }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{length}
\PYG{+w}{  }\PYG{n}{DG}\PYG{+w}{      }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{length}
\PYG{+w}{  }\PYG{n}{EF}\PYG{+w}{      }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{length}
\PYG{+w}{  }\PYG{n}{DE}\PYG{+w}{      }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{length}
\PYG{+w}{  }\PYG{n}{FG}\PYG{+w}{      }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{length}
