\PYG{+w}{  }\PYG{n}{u15}\PYG{+w}{     }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{u3375}\PYG{+w}{   }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C1}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C1 L = AD L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C2 L = AB L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C3}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C3 L = BD L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C4}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C4 L = AG L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C5}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C5 L = AC L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C6}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C6 L = CG L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C7}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C7 L = DG L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C8}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C8 L = EF L\PYGZdq{}}
\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{C9}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}C9 L = DE L + FG L\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{R1}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}R1 L = C1 L + C2 L + C3 L\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{R2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}R2 L = C4 L + C5 L + C6 L\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{R3}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} length\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}R3 L = C7 L + C8 L + C9 L\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}1. Matrice deduite des mesures du plan\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{M1\PYGZus{}L1}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}M1\PYGZus{}L1 L \PYGZlt{}\PYGZhy{}\PYGZgt{}}
\PYG{l+s}{     C1 L * diam\PYGZus{}eq L + C2 L * diam\PYGZus{}eq L + C3 L * diam\PYGZus{}eq L}
\PYG{l+s}{       = 2 * C1 L * diam\PYGZus{}eq L\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{M1\PYGZus{}L2}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}M1\PYGZus{}L2 L \PYGZlt{}\PYGZhy{}\PYGZgt{}}
\PYG{l+s}{     C4 L * u15 L + C5 L * u15 L + C6 L * u15 L}
\PYG{l+s}{       = 2 * C4 L * u15 L\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{M1\PYGZus{}L3}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}M1\PYGZus{}L3 L \PYGZlt{}\PYGZhy{}\PYGZgt{}}
\PYG{l+s}{     C7 L * u3375 L + C8 L * u3375 L + C9 L * u3375 L}
\PYG{l+s}{       = 2 * C7 L * u3375 L\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{M1\PYGZus{}matrix}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}cardan\PYGZus{}lengths =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}M1\PYGZus{}matrix L \PYGZlt{}\PYGZhy{}\PYGZgt{} M1\PYGZus{}L1 L \PYGZam{} M1\PYGZus{}L2 L \PYGZam{} M1\PYGZus{}L3 L\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}2. Matrice de transition\PYGZdq{}}

\PYG{k}{record}\PYG{+w}{ }\PYG{n}{drift\PYGZus{}transition}\PYG{+w}{ }\PYG{o}{=}
\PYG{+w}{  }\PYG{n}{C1\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C2\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C3\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C4\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C5\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C6\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C7\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C8\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{C9\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{R1\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{R2\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{R3\PYGZsq{}}\PYG{+w}{  }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{diam\PYGZus{}eq\PYGZsq{}}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{u15\PYGZsq{}}\PYG{+w}{     }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}
\PYG{+w}{  }\PYG{n}{u3375\PYGZsq{}}\PYG{+w}{   }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Structure de la matrice de transition :}

\PYG{l+s}{    C1\PYGZsq{} + C2\PYGZsq{} + C3\PYGZsq{} = R1\PYGZsq{}}
\PYG{l+s}{    C4\PYGZsq{} + C5\PYGZsq{} + C6\PYGZsq{} = R2\PYGZsq{}}
\PYG{l+s}{    C7\PYGZsq{} + C8\PYGZsq{} + C9\PYGZsq{} = R3\PYGZsq{}}

\PYG{l+s}{    R1\PYGZsq{} = 2 * C1\PYGZsq{} * diam\PYGZus{}eq\PYGZsq{}}
\PYG{l+s}{    R2\PYGZsq{} = 2 * C3\PYGZsq{} * u15\PYGZsq{}}
\PYG{l+s}{    R3\PYGZsq{} = 2 * C6\PYGZsq{} * u3375\PYGZsq{}}
\PYG{l+s}{\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{M2\PYGZus{}structure}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}drift\PYGZus{}transition =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}M2\PYGZus{}structure T \PYGZlt{}\PYGZhy{}\PYGZgt{}}
\PYG{l+s}{     C1\PYGZsq{} T + C2\PYGZsq{} T + C3\PYGZsq{} T = R1\PYGZsq{} T \PYGZam{}}
\PYG{l+s}{     C4\PYGZsq{} T + C5\PYGZsq{} T + C6\PYGZsq{} T = R2\PYGZsq{} T \PYGZam{}}
\PYG{l+s}{     C7\PYGZsq{} T + C8\PYGZsq{} T + C9\PYGZsq{} T = R3\PYGZsq{} T \PYGZam{}}
\PYG{l+s}{     R1\PYGZsq{} T = 2 * C1\PYGZsq{} T * diam\PYGZus{}eq\PYGZsq{} T \PYGZam{}}
\PYG{l+s}{     R2\PYGZsq{} T = 2 * C3\PYGZsq{} T * u15\PYGZsq{} T \PYGZam{}}
\PYG{l+s}{     R3\PYGZsq{} T = 2 * C6\PYGZsq{} T * u3375\PYGZsq{} T\PYGZdq{}}

\PYG{+w}{  }\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}3. Matrice a derivee premiere simplifiee\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Matrice simplifiee (nombres premiers) :}

\PYG{l+s}{    L1 : 37x + 31x + 29x = 41x}
\PYG{l+s}{    L2 : 19y + 17y + 13y = 23y}
\PYG{l+s}{    L3 :  7z +  5z +  3z = 11z}

\PYG{l+s}{  Version ponderee avec l\PYGZsq{}inconnue unique u = sqrt 3.375 :}

\PYG{l+s}{    L1 : 37 (7/48.5) u + 31 (7/48.5) u + 29 (7/48.5) u = 41 (7/20.5) u}
\PYG{l+s}{    L2 : 19 (7/24.5) u + 17 (7/24.5) u + 13 (7/24.5) u = 23 (7/11.5) u}
\PYG{l+s}{    L3 :  7 (7/7.5)  u +  5 (7/7.5)  u +  3 (7/7.5)  u = 11 (7/5.5)  u}
\PYG{l+s}{\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{u}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{real}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}u = sqrt (3.375 :: real)\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{L1\PYGZus{}simplified}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}real =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L1\PYGZus{}simplified x \PYGZlt{}\PYGZhy{}\PYGZgt{} 37*x + 31*x + 29*x = 41*x\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{L2\PYGZus{}simplified}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}real =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L2\PYGZus{}simplified y \PYGZlt{}\PYGZhy{}\PYGZgt{} 19*y + 17*y + 13*y = 23*y\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{L3\PYGZus{}simplified}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}real =\PYGZgt{} bool\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L3\PYGZus{}simplified z \PYGZlt{}\PYGZhy{}\PYGZgt{} 7*z + 5*z + 3*z = 11*z\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{L1\PYGZus{}weighted}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{bool}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L1\PYGZus{}weighted \PYGZlt{}\PYGZhy{}\PYGZgt{}}
\PYG{l+s}{     37 * (7/48.5) * u +}
\PYG{l+s}{     31 * (7/48.5) * u +}
\PYG{l+s}{     29 * (7/48.5) * u =}
\PYG{l+s}{     41 * (7/20.5) * u\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{L2\PYGZus{}weighted}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{bool}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L2\PYGZus{}weighted \PYGZlt{}\PYGZhy{}\PYGZgt{}}
\PYG{l+s}{     19 * (7/24.5) * u +}
\PYG{l+s}{     17 * (7/24.5) * u +}
\PYG{l+s}{     13 * (7/24.5) * u =}
\PYG{l+s}{     23 * (7/11.5) * u\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{L3\PYGZus{}weighted}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{bool}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L3\PYGZus{}weighted \PYGZlt{}\PYGZhy{}\PYGZgt{}}
\PYG{l+s}{     7 * (7/7.5) * u +}
\PYG{l+s}{     5 * (7/7.5) * u +}
\PYG{l+s}{     3 * (7/7.5) * u =}
\PYG{l+s}{     11 * (7/5.5) * u\PYGZdq{}}


\PYG{g+gu}{subsection}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}D1.0 Generalisation du facteur trigonometrique alternatif\PYGZdq{}}

\PYG{k}{text}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}}
\PYG{l+s}{  Definitions et lemmes liant l\PYGZsq{}expression trigonometrique alt\PYGZus{}factor au}
\PYG{l+s}{  rapport geometrique hauteur/demi\PYGZhy{}base = 1 / sqrt p. On introduit aussi la}
\PYG{l+s}{  notion de diametre equivalent au carre.}
\PYG{l+s}{\PYGZdq{}}

\PYG{k}{definition}\PYG{+w}{ }\PYG{n}{inv\PYGZus{}ratio\PYGZus{}height\PYGZus{}halfbase}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{l+s}{\PYGZdq{}nat =\PYGZgt{} nat =\PYGZgt{} real\PYGZdq{}}\PYG{+w}{ }\PYG{k+kp}{where}
\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}inv\PYGZus{}ratio\PYGZus{}height\PYGZus{}halfbase n p = 1 / ratio\PYGZus{}halfbase\PYGZus{}height n p\PYGZdq{}}

\PYG{k+kn}{lemma}\PYG{+w}{ }\PYG{n}{inv\PYGZus{}ratio\PYGZus{}height\PYGZus{}halfbase\PYGZus{}simpl}\PYG{o}{:}
\PYG{+w}{  }\PYG{k+kp}{fixes}\PYG{+w}{ }\PYG{n}{n}\PYG{+w}{ }\PYG{o}{::}\PYG{+w}{ }\PYG{n}{nat}
