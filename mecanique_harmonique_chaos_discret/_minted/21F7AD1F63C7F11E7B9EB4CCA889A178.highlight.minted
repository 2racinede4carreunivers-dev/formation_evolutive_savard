\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L1\PYGZus{}simplified x }\PYG{l+s+ss}{\PYGZbs{}\PYGZlt{}longleftrightarrow\PYGZgt{}}\PYG{l+s}{ 37*x + 31*x + 29*x = 41*x\PYGZdq{}}

