\PYG{+w}{  }\PYG{l+s}{\PYGZdq{}L2\PYGZus{}simplified y }\PYG{l+s+ss}{\PYGZbs{}\PYGZlt{}longleftrightarrow\PYGZgt{}}\PYG{l+s}{ 19*y + 17*y + 13*y = 23*y\PYGZdq{}}

